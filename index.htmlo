    <!-- 🔍 Overlay -->
    <div id="searchOverlay">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h2 style="font-size:28px; font-weight:800; letter-spacing:-1px;">Results</h2>
            <i class="fa-solid fa-circle-xmark" onclick="closeSearch()" style="font-size:30px; opacity:0.5;"></i>
        </div>
        <div id="searchResults"></div>
    </div>

    <script>
        async function fetchStats() {
            try {
                const res = await fetch('api_reports.php?action=kpi');
                const data = await res.json();
                document.getElementById('todaySales').innerText = '₹' + (data.todaySales || 0).toLocaleString();
                document.getElementById('monthlySales').innerText = '₹' + (data.monthlySales || 0).toLocaleString();
                
                // Feature 7: Stock Alert
                fetch('api_master_data.php?action=get_stock_count')
                .then(r => r.json())
                .then(stock => {
                    if(stock.total < 5) document.getElementById('stockAlert').style.display='flex';
                });
            } catch(e) {}
        }

        let searchT;
        function handleSearch(q) {
            const overlay = document.getElementById('searchOverlay');
            if(!q || q.length < 2) { overlay.style.display = 'none'; return; }
            
            clearTimeout(searchT);
            searchT = setTimeout(async () => {
                const r = await fetch(`api_global_search.php?q=${encodeURIComponent(q)}`);
                const data = await r.json();
                const container = document.getElementById('searchResults');
                if(data.results && data.results.length > 0) {
                    container.innerHTML = data.results.map(res => `
                        <a href="${res.link}" style="display:flex; align-items:center; gap:20px; background:rgba(255,255,255,0.03); padding:20px; border-radius:24px; margin-bottom:15px; text-decoration:none; color:inherit; border:1px solid rgba(255,255,255,0.08);">
                            <div style="width:50px; height:50px; background:linear-gradient(135deg, #8b5cf6, #3b82f6); border-radius:16px; display:flex; align-items:center; justify-content:center; color:white;"><i class="fa-solid fa-magnifying-glass"></i></div>
                            <div>
                                <div style="font-weight:700; font-size:16px;">${res.title}</div>
                                <div style="font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-top:4px;">${res.type} • ${res.subtitle}</div>
                            </div>
                        </a>
                    `).join('');
                } else {
                    container.innerHTML = '<div style="text-align:center; padding:50px; color:var(--text-muted);">No records found. Try a different term.</div>';
                }
                overlay.style.display = 'block';
            }, 300);
        }

        function closeSearch() {
            document.getElementById('searchOverlay').style.display = 'none';
            document.getElementById('omniSearch').value = '';
        }

        async function askAI(q) {
            if(!q) return;
            const input = document.getElementById('aiQuery');
            const originalVal = input.placeholder;
            input.value = '';
            input.placeholder = "🧠 Thinking...";
            
            try {
                const res = await fetch(`api_ai_assistant.php?q=${encodeURIComponent(q)}`);
                const data = await res.json();
                
                // Show in results overlay or alert
                const container = document.getElementById('searchResults');
                container.innerHTML = `
                    <div style="background:linear-gradient(135deg, #1e1b4b, #0f172a); padding:30px; border-radius:32px; border:1px solid var(--primary); box-shadow:0 20px 50px rgba(0,0,0,0.5);">
                        <div style="color:var(--primary); font-size:12px; font-weight:800; margin-bottom:15px; text-transform:uppercase; letter-spacing:2px;">SK-AI Assistant</div>
                        <div style="font-size:20px; font-weight:600; line-height:1.5; color:white;">${data.answer}</div>
                        <button onclick="closeSearch()" style="margin-top:25px; width:100%; padding:15px; border-radius:15px; background:var(--primary); border:none; color:white; font-weight:800;">OK, GOT IT</button>
                    </div>
                `;
                document.getElementById('searchOverlay').style.display = 'block';
            } catch(e) {
                alert("AI Link Failed");
            } finally {
                input.placeholder = originalVal;
            }
        }

        window.onload = fetchStats;

        // Vibrate on touch
        document.querySelectorAll('a').forEach(lnk => {
            lnk.onmousedown = () => { if(window.navigator.vibrate) window.navigator.vibrate(12); };
        });
    </script>
</body>
</html>
